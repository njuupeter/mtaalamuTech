{
  "entities": {
    "Service": {
      "title": "Service",
      "description": "A service offered by MtaalamuTech",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "iconName": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["name", "description", "category", "price", "iconName"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A service booking request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "serviceId": { "type": "string" },
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["serviceId", "customerName", "phone", "status", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record for a booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bookingId": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "successful", "failed"] },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bookingId", "amount", "method", "status", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Customer feedback and rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "message": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "rating", "message", "approved", "createdAt"]
    },
    "News": {
      "title": "News",
      "description": "Company news or blog post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Collection of services"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of bookings"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Collection of payments"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of feedback"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Collection of news posts"
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Collection of admin users"
    }
  }
}
